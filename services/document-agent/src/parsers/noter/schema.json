{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://finatura.app/schemas/noter-satis-sozlesmesi-ocr-result.json",
  "title": "NoterSatisSozlesmesiOcrResult",
  "description": "Noter araç satış sözleşmesi OCR çıktısı — plaka, şasi, bedel, alıcı/satıcı TCKN",
  "type": "object",
  "additionalProperties": false,
  "required": ["fields", "confidence", "overallConfidence", "warnings"],
  "properties": {
    "fields": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plaka",
        "saseNo",
        "satisBedeli",
        "paraBirimi",
        "aliciTckn",
        "saticiTckn",
        "belgeTuru"
      ],
      "properties": {
        "plaka": {
          "type": ["string", "null"],
          "pattern": "^(0[1-9]|[1-7][0-9]|8[01]) [A-ZÇĞİÖŞÜ]{1,3} \\d{2,4}$",
          "description": "Normalize TR plaka"
        },
        "saseNo": {
          "type": ["string", "null"],
          "pattern": "^[A-HJ-NPR-Z0-9]{17}$",
          "description": "17 karakter VIN / şasi no"
        },
        "satisBedeli": {
          "type": ["number", "null"],
          "minimum": 0,
          "description": "Satış bedeli (TRY)"
        },
        "paraBirimi": {
          "type": ["string", "null"],
          "enum": ["TRY", null]
        },
        "aliciTckn": {
          "type": ["string", "null"],
          "pattern": "^[1-9][0-9]{10}$",
          "description": "Alıcı TCKN"
        },
        "saticiTckn": {
          "type": ["string", "null"],
          "pattern": "^[1-9][0-9]{10}$",
          "description": "Satıcı TCKN"
        },
        "belgeTuru": {
          "type": "string",
          "enum": ["noter_satis_sozlesmesi", "unknown"]
        }
      }
    },
    "confidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plaka",
        "saseNo",
        "satisBedeli",
        "aliciTckn",
        "saticiTckn",
        "belgeTuru"
      ],
      "properties": {
        "plaka": { "type": "number", "minimum": 0, "maximum": 1 },
        "saseNo": { "type": "number", "minimum": 0, "maximum": 1 },
        "satisBedeli": { "type": "number", "minimum": 0, "maximum": 1 },
        "aliciTckn": { "type": "number", "minimum": 0, "maximum": 1 },
        "saticiTckn": { "type": "number", "minimum": 0, "maximum": 1 },
        "belgeTuru": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "overallConfidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "extractedBy": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "enum": ["regex", "llm"]
      }
    },
    "rawText": {
      "type": "string"
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
