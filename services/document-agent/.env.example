PORT=3100
NODE_ENV=development

# OCR sağlayıcısı: tesseract (varsayılan, gerçek OCR) | stub (yalnızca açıkça)
OCR_PROVIDER=tesseract
TESSERACT_LANGS=tur+eng

# Varsayılan: tamamen yerel (Tesseract + regex). Dış AI maliyeti yok.
# LLM_ENABLED=true  # yalnızca açıkça açılırsa OpenAI/Anthropic/Gemini kullanılır
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
