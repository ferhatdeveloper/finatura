PORT=3100
NODE_ENV=development

# OCR sağlayıcısı: tesseract (varsayılan, gerçek OCR) | stub (yalnızca açıkça)
OCR_PROVIDER=tesseract
TESSERACT_LANGS=tur+eng

# --- OpenRouter (OCR alan çıkarımı) ---
# LLM_ENABLED=true
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini
# LLM_HTTP_REFERER=https://finatura.app
# LLM_APP_TITLE=Finatura
#
# Superadmin panelinden ayar çekmek için (env yoksa):
# LLM_SETTINGS_URL=http://finatura_api:3000
# INTERNAL_SERVICE_TOKEN=<api-gateway ile aynı>

# Diğer sağlayıcılar (opsiyonel)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
