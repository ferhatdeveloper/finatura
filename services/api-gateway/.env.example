# Sunucu
PORT=3000
NODE_ENV=development

# JWT (geliÅŸtirme stub â€” Ã¼retimde gÃ¼Ã§lÃ¼ secret + KMS/rotation kullanÄ±n)
JWT_SECRET=finatura-dev-jwt-secret-change-me
JWT_ISSUER=finatura.api-gateway
JWT_AUDIENCE=finatura.app
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

# Auth saÄŸlayÄ±cÄ±: stub (yerel) | central (users + memberships; production prefer)
# Production path: AUTH_PROVIDER=central + CENTRAL_DATABASE_URL
AUTH_PROVIDER=stub
# AUTH_PROVIDER=central iken zorunlu (yerel compose :5440):
# CENTRAL_DATABASE_URL=postgresql://finatura:finatura_dev@localhost:5440/finatura_central

# Auth stub â€” AUTH_PROVIDER=stub iÃ§in demo kullanÄ±cÄ±
AUTH_STUB_EMAIL=demo@finatura.app
AUTH_STUB_PASSWORD=demo1234
AUTH_STUB_USER_ID=00000000-0000-4000-8000-000000000001
AUTH_STUB_TENANT_ID=00000000-0000-4000-8000-0000000000aa
AUTH_STUB_TENANT_SLUG=ornek-galeri
# Web form alanÄ± firmaKodu (mali_musavir_kodu eÅŸdeÄŸeri)
AUTH_STUB_FIRMA_KODU=DEMO-GALERI
# owner | admin | member | viewer | accountant
AUTH_STUB_ROLE=owner

# Tenant context
# JWT claim'deki tenantId ile X-Tenant-ID uyumsuzsa 403
TENANT_HEADER=x-tenant-id
REQUIRE_TENANT_HEADER=false

# Rate limit (placeholder â€” gerÃ§ek Redis/store sonra baÄŸlanacak)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Downstream tenant-router (proxy: /v1/tenant/* â†’ /api/tenant/*)
# Docker/Dokploy: http://finatura_router:3100
# Yerel gelişim: http://localhost:3100
TENANT_ROUTER_URL=http://finatura_router:3100
# TRUNCGIL_RATES_URL=https://finans.truncgil.com/v4/today.json
# DATSHOP_RATES_URL=https://datshop.com.tr
# RATES_SOURCE_URL=
TENANT_ROUTER_TIMEOUT_MS=10000

