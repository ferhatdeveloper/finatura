# Sunucu
PORT=3000
NODE_ENV=development

# JWT (geliştirme stub — üretimde güçlü secret + KMS/rotation kullanın)
JWT_SECRET=finatura-dev-jwt-secret-change-me
JWT_ISSUER=finatura.api-gateway
JWT_AUDIENCE=finatura.app
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

# Auth sağlayıcı: stub (varsayılan, DB yok) | central (users + memberships)
AUTH_PROVIDER=stub
# AUTH_PROVIDER=central iken zorunlu (yerel compose :5440 — RetailEX :5432 ile çakışmaz):
# CENTRAL_DATABASE_URL=postgresql://finatura:finatura@localhost:5440/finatura_central

# Auth stub — AUTH_PROVIDER=stub için demo kullanıcı
AUTH_STUB_EMAIL=demo@finatura.app
AUTH_STUB_PASSWORD=demo1234
AUTH_STUB_USER_ID=00000000-0000-4000-8000-000000000001
AUTH_STUB_TENANT_ID=00000000-0000-4000-8000-0000000000aa
AUTH_STUB_TENANT_SLUG=ornek-galeri
# Web form alanı firmaKodu (mali_musavir_kodu eşdeğeri)
AUTH_STUB_FIRMA_KODU=DEMO-GALERI
# owner | admin | member | viewer | accountant
AUTH_STUB_ROLE=owner

# Tenant context
# JWT claim'deki tenantId ile X-Tenant-ID uyumsuzsa 403
TENANT_HEADER=x-tenant-id
REQUIRE_TENANT_HEADER=false

# Rate limit (placeholder — gerçek Redis/store sonra bağlanacak)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Downstream tenant-router (proxy: /v1/tenant/* → /api/tenant/*)
TENANT_ROUTER_URL=http://localhost:3100
TENANT_ROUTER_TIMEOUT_MS=10000
