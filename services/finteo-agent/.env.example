# Ã‡alÄ±ÅŸma ortamÄ±
NODE_ENV=development

# Central DB — docker-compose.yml → postgres-central (:5440)
# Kullanıcı/parola: finatura / finatura_dev
CENTRAL_DATABASE_URL=postgresql://finatura:finatura_dev@localhost:5440/finatura_central

# Poll aralÄ±ÄŸÄ± (milisaniye). VarsayÄ±lan: 10 dakika
POLL_INTERVAL_MS=600000

# BaÅŸlangÄ±Ã§ta hemen bir tur Ã§alÄ±ÅŸtÄ±r (true/false)
POLL_RUN_ON_START=true

# Finteo API â€” production defaults: http (mock kapalÄ±)
FINTEO_API_BASE_URL=https://api.finteo.com/v1
FINTEO_API_KEY=
FINTEO_CLIENT_MODE=http
# http (varsayÄ±lan) | mock
# http iken FINTEO_API_KEY + FINTEO_API_BASE_URL zorunlu; yoksa net hata (mockâ€™a dÃ¼ÅŸÃ¼lmez)
# Yerel fixture / offline: FINTEO_CLIENT_MODE=mock

# Env-based endpoint ÅŸablonlarÄ± (resmi OpenAPI gelene kadar)
FINTEO_TRANSACTIONS_PATH=/accounts/{accountRef}/transactions
FINTEO_TRANSACTIONS_LIST_PATH=/transactions
FINTEO_SINCE_QUERY_PARAM=since
FINTEO_AUTH_HEADER=Authorization
FINTEO_AUTH_SCHEME=Bearer
FINTEO_TIMEOUT_MS=30000
# FINTEO_EXTRA_QUERY=pageSize=100

# Matching bridge (sync sonrasÄ± unmatched â†’ matching-agent)
# off | inprocess | http
MATCHING_BRIDGE_MODE=inprocess
# MATCHING_AGENT_URL=http://localhost:7090
MATCHING_MIN_SCORE=25
MATCHING_LIMIT=5
MATCHING_HTTP_TIMEOUT_MS=15000

# Tenant pool
POOL_MAX=5
POOL_IDLE_TIMEOUT_MS=30000

# Ä°steÄŸe baÄŸlÄ±: yalnÄ±zca bu tenant id'lerini tara (virgÃ¼lle). BoÅŸsa tÃ¼m aktif tenant'lar.
# TENANT_IDS=
