# Çalışma ortamı
NODE_ENV=development

# Central DB — aktif tenant listesi buradan okunur
CENTRAL_DATABASE_URL=postgresql://finatura:finatura@localhost:5440/finatura_central

# Poll aralığı (milisaniye). Varsayılan: 10 dakika
POLL_INTERVAL_MS=600000

# Başlangıçta hemen bir tur çalıştır (true/false)
POLL_RUN_ON_START=true

# Finteo API
FINTEO_API_BASE_URL=https://api.finteo.example/v1
FINTEO_API_KEY=replace_me
FINTEO_CLIENT_MODE=mock
# mock | http  — http mock/sandbox'a düşmez; anahtar + endpoint gerekir

# Env-based endpoint şablonları (resmi OpenAPI gelene kadar)
FINTEO_TRANSACTIONS_PATH=/accounts/{accountRef}/transactions
FINTEO_TRANSACTIONS_LIST_PATH=/transactions
FINTEO_SINCE_QUERY_PARAM=since
FINTEO_AUTH_HEADER=Authorization
FINTEO_AUTH_SCHEME=Bearer
FINTEO_TIMEOUT_MS=30000
# FINTEO_EXTRA_QUERY=pageSize=100

# Matching bridge (sync sonrası unmatched → matching-agent)
# off | inprocess | http
MATCHING_BRIDGE_MODE=inprocess
# MATCHING_AGENT_URL=http://localhost:7090
MATCHING_MIN_SCORE=25
MATCHING_LIMIT=5
MATCHING_HTTP_TIMEOUT_MS=15000

# Tenant pool
POOL_MAX=5
POOL_IDLE_TIMEOUT_MS=30000

# İsteğe bağlı: yalnızca bu tenant id'lerini tara (virgülle). Boşsa tüm aktif tenant'lar.
# TENANT_IDS=
