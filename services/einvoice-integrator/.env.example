# Sunucu
PORT=3200
NODE_ENV=development

# Aktif entegratör: edm | uyumsoft | fit | elogo | qnb | nes | nilvera | izibiz
EINVOICE_PROVIDER=edm

# --- Production defaults ---
# EINVOICE_STUB_MODE=false (varsayılan kod): canlı SOAP/REST yolu.
# Credential yoksa istek 503 / missing_credentials döner (mock’a düşülmez).
# Yerel CI / bayilik anahtarı yokken: EINVOICE_STUB_MODE=true
EINVOICE_STUB_MODE=false

# --- Bayilik notu ---
# Finatura müşteriye kontör satar; canlı ortam için EDM / Uyumsoft / FIT / eLogo / QNB / NES / Nilvera / İzibiz
# bayilik hesabından alınan WS/OAuth/API Key + test/prod endpoint kullanılır.
# VKN ve GB/PK alias değerleri bayilik paneline göre doldurulmalıdır.

# --- EDM (live: Login + SendInvoice SOAP) ---
# Test örnek: https://test.edmbilisim.com.tr
EDM_BASE_URL=https://test.edmbilisim.com.tr
EDM_USERNAME=
EDM_PASSWORD=
EDM_VKN=
# EDM_API_KEY=
# Opsiyonel GB/PK alias (yoksa skeleton varsayılan üretir)
# EDM_GB_ALIAS=urn:mail:defaultgb@firma.com.tr
# EDM_PK_ALIAS=urn:mail:defaultpk@alici.com.tr

# --- Uyumsoft (live: BasicIntegration SOAP) ---
# Test örnek: https://efatura-test.uyumsoft.com.tr
UYUMSOFT_BASE_URL=https://efatura-test.uyumsoft.com.tr
UYUMSOFT_USERNAME=
UYUMSOFT_PASSWORD=
UYUMSOFT_VKN=
# UYUMSOFT_API_KEY=

# --- FIT / Foriba / Sovos (live: SendUBL SOAP) ---
# Test örnek: https://earsivwstest.fitbulut.com (bayilikten kesin URL alın)
FIT_BASE_URL=https://earsivwstest.fitbulut.com
FIT_USERNAME=
FIT_PASSWORD=
FIT_VKN=
# FIT_API_KEY=
# FIT_GB_ALIAS=urn:mail:defaultgb@firma.com.tr
# FIT_PK_ALIAS=urn:mail:defaultpk@alici.com.tr

# --- Logo eLogo (live: Login + SendDocument SOAP / PostBoxService) ---
# Test örnek: https://betatest.elogo.com.tr
ELOGO_BASE_URL=https://betatest.elogo.com.tr
ELOGO_USERNAME=
ELOGO_PASSWORD=
ELOGO_VKN=
# ELOGO_API_KEY=
# Opsiyonel GB/PK alias
# ELOGO_GB_ALIAS=urn:mail:defaultgb@firma.com.tr
# ELOGO_PK_ALIAS=urn:mail:defaultpk@alici.com.tr

# --- QNB eSolutions / eFinans (live: wsLogin + belgeGonderExt SOAP) ---
# Test örnek: https://connectortest.efinans.com.tr
QNB_BASE_URL=https://connectortest.efinans.com.tr
QNB_USERNAME=
QNB_PASSWORD=
QNB_VKN=
# QNB_API_KEY=
# Opsiyonel ERP kodu (bayilikten)
# QNB_ERP_CODE=FINATURA

# --- NES (live: OAuth2 + REST) ---
# Test/prod örnek: https://api.nes.com.tr (bayilik Swagger’dan kesin path alın)
NES_BASE_URL=https://api.nes.com.tr
NES_CLIENT_ID=
NES_CLIENT_SECRET=
# Opsiyonel password grant (yoksa client_credentials)
# NES_USERNAME=
# NES_PASSWORD=
NES_VKN=
# NES_API_KEY=

# --- Nilvera (live: REST Bearer API Key) ---
# Test: https://apitest.nilvera.com  |  Prod: https://api.nilvera.com
# Portal → API Tanımları ile API Key; Authorization: Bearer {key}
NILVERA_BASE_URL=https://apitest.nilvera.com
NILVERA_API_KEY=
# Alternatif: API_KEY yoksa USERNAME + PASSWORD (token = password || username)
# NILVERA_USERNAME=
# NILVERA_PASSWORD=
NILVERA_VKN=
# NILVERA_PK_ALIAS=urn:mail:defaultpk@alici.com.tr
# NILVERA_TEMPLATE_UUID=

# --- İzibiz (live: AuthenticationWS Login + EInvoiceWS SOAP) ---
# Test: https://efaturatest.izibiz.com.tr  |  Prod: https://efatura.izibiz.com.tr
IZIBIZ_BASE_URL=https://efaturatest.izibiz.com.tr
IZIBIZ_USERNAME=
IZIBIZ_PASSWORD=
IZIBIZ_VKN=
# IZIBIZ_API_KEY=
# IZIBIZ_GB_ALIAS=urn:mail:defaultgb@firma.com.tr
# IZIBIZ_PK_ALIAS=urn:mail:defaultpk@alici.com.tr

# Opsiyonel: varsayılan gönderici VKN (tenant ayarından geldiğinde ezilir)
DEFAULT_SENDER_VKN=
