# Sunucu
PORT=3100
NODE_ENV=development

# Central (kontrol) veritabanı — docker-compose.yml → postgres-central
# Kullanıcı/parola: finatura / finatura_dev @ :5440
CENTRAL_DATABASE_URL=postgresql://finatura:finatura_dev@localhost:5440/finatura_central

# Tenant baÄŸlantÄ± Ã§Ã¶zÃ¼mÃ¼ (database/central/01_schema.sql)
# X-Tenant-ID â†’ tenants.id|slug + tenant_databases (password_ciphertext)
TENANT_LOOKUP_BY=id
# id | slug  â€” X-Tenant-ID deÄŸerinin eÅŸleÅŸeceÄŸi alan

# Connection pool cache
POOL_MAX=10
POOL_IDLE_TIMEOUT_MS=30000
POOL_CACHE_TTL_MS=300000
POOL_CACHE_MAX_ENTRIES=100

