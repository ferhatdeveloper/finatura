# Sunucu
PORT=3100
NODE_ENV=development

# Central (kontrol) veritabanı — tenant kayıtları burada tutulur
CENTRAL_DATABASE_URL=postgresql://finatura:finatura@localhost:5432/finatura_central

# Tenant bağlantı çözümü (database/central/01_schema.sql)
# X-Tenant-ID → tenants.id|slug + tenant_databases (password_ciphertext)
TENANT_LOOKUP_BY=id
# id | slug  — X-Tenant-ID değerinin eşleşeceği alan

# Connection pool cache
POOL_MAX=10
POOL_IDLE_TIMEOUT_MS=30000
POOL_CACHE_TTL_MS=300000
POOL_CACHE_MAX_ENTRIES=100

# Parola decrypt (stub varsayılan — üretimde KMS implementasyonu enjekte edilir)
# Lokal seed: password_ciphertext = plain:<parola> veya encryption_key_id = dev-plain
# PASSWORD_DECRYPTOR=stub
