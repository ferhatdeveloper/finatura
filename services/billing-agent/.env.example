# Sunucu
PORT=3200
NODE_ENV=development

# Central (kontrol) veritabanı — kontör bakiyesi ve ledger burada tutulur
CENTRAL_DATABASE_URL=postgresql://finatura:finatura@localhost:5440/finatura_central

# Birim maliyetler (kontör). Ortamdan override edilebilir.
KONTOR_COST_OCR_SOZLESME=1
KONTOR_COST_OCR_KIMLIK=1
KONTOR_COST_OCR_TAPU=1
KONTOR_COST_EFATURA_SEND=2

# --- Aşama 6.2 Ödeme geçidi ---
# stub | iyzico | paytr  (iyzico/paytr henüz stub'a düşer)
PAYMENT_PROVIDER=stub
# 3D / hostlu ödeme dönüş URL'si
PAYMENT_CALLBACK_URL=http://localhost:3200/api/payment/callback

# İyzico (üretimde doldurun; stub modunda zorunlu değil)
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# PayTR (üretimde doldurun; stub modunda zorunlu değil)
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
