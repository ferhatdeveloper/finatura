# Finatura — kök ortam özeti (örnek / dokümantasyon)
# Servis bazlı asıl örnekler: services/*/.env.example
#
# Yerel PostgreSQL:
#   docker compose up -d
#   → postgres-central :5432  finatura / finatura_dev  / finatura_central
#   → postgres-tenant  :5433  finatura_tenant / finatura_tenant_dev / tenant_ornek
#
# Backend varsayılanları (production path):
#   EINVOICE_STUB_MODE=false          # stub yalnızca credential yokken true
#   FINTEO_CLIENT_MODE=http           # mock yalnızca açıkça FINTEO_CLIENT_MODE=mock
#   OCR_PROVIDER=tesseract            # stub yalnızca OCR_PROVIDER=stub
# İstemci mock kapalı: SCAN_USE_MOCK_FALLBACK=false (Flutter dart-define)
# Dashboard: VITE_USE_MOCK=false (varsayılan canlı)
# MM portal: VITE_AUTH_MODE=gateway

# --- Ortak DB ---
# Yerel: docker compose up -d  → localhost:5440
# Dokploy: docker-compose.pg.yml → host finatura_pg (berqenas_net, host port YOK)
#   Volume: finatura_pg_data  (≠ saas_postgres_data / kargomkapinda_*)
CENTRAL_DATABASE_URL=postgresql://finatura:finatura_dev@localhost:5440/finatura_central
# Production örneği:
# CENTRAL_DATABASE_URL=postgresql://finatura:<şifre>@finatura_pg:5432/finatura_central
# AUTH_PROVIDER=central

# --- document-agent / OpenRouter OCR LLM ---
# OCR_PROVIDER=tesseract
# TESSERACT_LANGS=tur+eng
# LLM_ENABLED=true
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL=openai/gpt-4o-mini
# LLM_SETTINGS_URL=http://localhost:3000
# INTERNAL_SERVICE_TOKEN=finatura-internal-dev-token-change-me
# Superadmin UI: dashboard /sistem (admin@finatura.app) + SQL 07_system_settings.sql

# --- einvoice-integrator ---
# EINVOICE_PROVIDER=edm
# EINVOICE_STUB_MODE=false
# EDM_USERNAME=  EDM_PASSWORD=  EDM_VKN=

# --- finteo-agent ---
# FINTEO_CLIENT_MODE=http
# FINTEO_API_BASE_URL=https://api.finteo.com/v1
# FINTEO_API_KEY=

# --- api-gateway / tenant-router ---
# AUTH_PROVIDER=central
# TENANT_ROUTER_URL=http://localhost:3100
# Login body: { "identifier": "e-posta|telefon|TCKN|vergi", "password": "…" }
# Geriye uyum: "email" / "username" alanları da kabul edilir.
